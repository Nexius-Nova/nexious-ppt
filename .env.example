# ============================================
# 数据库配置示例文件
# 请复制此文件为 .env 并填写实际配置
# ============================================

# 数据库连接信息
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=nexious-ppt

# 数据库连接池配置
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRES_IN=1h
ACCESS_TOKEN_EXPIRES_SECONDS=3600
REFRESH_TOKEN_EXPIRES_DAYS=7

# 加密配置
ENCRYPTION_KEY=your-32-character-encryption-key

# 服务器配置
PORT=3001
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:5173
JSON_BODY_LIMIT=30mb

# 前端配置
VITE_API_URL=http://localhost:3001

# 持久化存储根路径
# 生产环境建议使用绝对路径，例如 /var/lib/nexious-ppt
STORAGE_ROOT=.generated

# Python 导出运行时
# 生产环境部署脚本会自动创建 .venv 并注入 PYTHON_BIN
PYTHON_BIN=.venv/bin/python

# Redis配置
REDIS_URL=redis://localhost:6379
QUEUE_DRIVER=redis
REDIS_QUEUE_PREFIX=nexious:ppt
GENERATION_QUEUE_CONCURRENCY=3
EXPORT_QUEUE_CONCURRENCY=2
EXECUTOR_PAGE_CONCURRENCY=3
IMAGE_GENERATION_CONCURRENCY=3
# 生产环境建议为 true；NODE_ENV=production 且 QUEUE_DRIVER!=memory 时 Redis 预检失败会阻止任务入队
REDIS_QUEUE_STRICT=true
# 设置为 true 时，启动时输出 Redis 版本和 maxmemory-policy 诊断提示
REDIS_QUEUE_DIAGNOSTICS=false

# Skill 运行沙箱限制
SKILL_RUN_TIMEOUT_MS=120000
SKILL_RUN_OUTPUT_BYTES=1048576
SKILL_RUN_CONCURRENCY=2

# 上传与远程图片代理限制
PROXY_IMAGE_MAX_BYTES=8388608
TEMPLATE_IMPORT_MAX_BYTES=52428800
AVATAR_MAX_BYTES=2097152
PROMPT_PREVIEW_IMAGE_MAX_BYTES=8388608

# 邮件验证码配置
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Nexious API <noreply@nexious-api.com>
EMAIL_CODE_TTL_SECONDS=300
EMAIL_CODE_COOLDOWN_SECONDS=60
EMAIL_CODE_MAX_PER_HOUR=6
EMAIL_CODE_MAX_VERIFY_ATTEMPTS=5
AUTH_REDIS_PREFIX=nexious:auth
EMAIL_CODE_SECRET=change-this-email-code-secret
