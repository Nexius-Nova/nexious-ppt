{
  "name": "nexious-ppt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.2",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:client\" \"pnpm run dev:server\" \"pnpm run dev:worker\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/start.ts",
    "dev:worker": "tsx watch server/worker.ts",
    "dev:all": "pnpm run dev",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "vue-tsc --noEmit",
    "init-db": "tsx server/scripts/init-db.ts",
    "migrate": "tsx server/scripts/migrate.ts",
    "verify-db": "tsx server/scripts/verify-db.ts",
    "cleanup-generated": "tsx server/scripts/cleanup-generated-assets.ts",
    "server": "tsx server/start.ts",
    "worker": "tsx server/worker.ts"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^0.468.0",
    "mysql2": "^3.6.5",
    "pdf-parse": "^2.4.5",
    "pinia": "^3.0.2",
    "pptxgenjs": "^4.0.1",
    "uuid": "^9.0.1",
    "vite": "^6.3.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10"
  }
}
